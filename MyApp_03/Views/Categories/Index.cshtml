@model List<Category>

@{
    ViewData["Title"] = "Categoreis";
}


<div>
    <div>
        <h4>Category List</h4>
        <a href="@Url.Action("Create","Categories")" class=" btn btn-light">Create</a>
    </div>
    <table class="table table-responsive">
        <thead>
            <tr>
                <th scope="col">No</th>
                <th scope="col">Name</th>
                <th scope="col">Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <th scope="row">@category.CategoryId</th>
                    <td>@category.Name</td>
                    <td>
                        <a
                            asp-controller="Categories" 
                            asp-action="Edit" 
                            asp-route-id="@category.CategoryId" 
                            class="btn btn-info"
                        >Edit
                        </a>
                        <a asp-controller="Categories"
                               asp-action="Detail"
                               asp-route-id="@category.CategoryId"
                               class="btn btn-info">
                            Detail
                        </a>
                    </td>
                </tr>
                
            }
        </tbody>
    </table>
</div>